---
const columns = [
	{ title: 'Product', links: ['Wardrobe', 'Outfits', 'Planner', 'Discover'] },
	{ title: 'System', links: ['Privacy', 'Auto-tagging', 'Calendar', 'Export'] },
	{ title: 'Guides', links: ['Capsules', 'Declutter', 'Packing', 'Cost per wear'] },
	{ title: 'Company', links: ['About', 'Security', 'Updates', 'Contact'] },
];
---

<footer class="border-t border-hairline bg-canvas">
	<div class="container-page grid gap-10 py-16 lg:grid-cols-[1.2fr_2fr]">
		<div>
			<p class="font-mono text-xs text-body">PRIVATE WARDROBE OS</p>
			<p class="mt-4 max-w-sm text-2xl font-semibold leading-8 text-ink">
				A calmer way to know what you own, what works, and what to wear next.
			</p>
		</div>
		<div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
			{columns.map((column) => (
				<div>
					<p class="font-mono text-xs text-mute">{column.title}</p>
					<div class="mt-4 grid gap-2">
						{column.links.map((link) => (
							<a class="text-sm text-body transition hover:text-ink" href="/settings">{link}</a>
						))}
					</div>
				</div>
			))}
		</div>
	</div>
</footer>
