---
const { eyebrow, title, body, align = 'left' } = Astro.props;
---

<div class:list={['max-w-3xl', align === 'center' && 'mx-auto text-center']}>
	{eyebrow && <p class="font-mono text-xs uppercase text-body">{eyebrow}</p>}
	<h2 class="mt-3 text-3xl font-semibold leading-10 text-ink md:text-[32px]">
		{title}
	</h2>
	{body && <p class="mt-4 text-base leading-7 text-body md:text-lg">{body}</p>}
</div>
