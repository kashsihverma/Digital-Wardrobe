---
import { CalendarCheck, CloudSun } from '@lucide/astro';
import type { EventPlan } from '../../data/wardrobe';

const { event } = Astro.props as { event: EventPlan };
---

<article class="rounded-lg border border-hairline bg-canvas p-4 shadow-[var(--shadow-card)]">
	<div class="flex items-start gap-3">
		<div class="flex size-11 shrink-0 items-center justify-center rounded-full bg-canvas-soft text-ink">
			<CalendarCheck size={18} stroke-width={1.8} />
		</div>
		<div class="min-w-0 flex-1">
			<div class="flex items-center justify-between gap-3">
				<p class="font-mono text-xs text-body">{event.date}</p>
				<span class="rounded-full bg-canvas-soft px-2 py-1 text-xs text-body">{event.status}</span>
			</div>
			<h3 class="mt-1 text-base font-semibold text-ink">{event.title}</h3>
			<div class="mt-3 grid gap-2 text-sm text-body">
				<p>{event.outfit}</p>
				<p class="flex items-center gap-2">
					<CloudSun size={15} stroke-width={1.8} />
					{event.weather} · {event.dressCode}
				</p>
			</div>
		</div>
	</div>
</article>
