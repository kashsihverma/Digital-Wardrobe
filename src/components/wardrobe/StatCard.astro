---
const { label, value, detail } = Astro.props;
---

<article class="rounded-lg border border-hairline bg-canvas p-5 shadow-[var(--shadow-card)]">
	<p class="font-mono text-xs text-body">{label}</p>
	<p class="mt-3 text-3xl font-semibold text-ink">{value}</p>
	<p class="mt-2 text-sm text-body">{detail}</p>
</article>
