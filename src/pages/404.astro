---
import Layout from '../layouts/Layout.astro';
import AppShell from '../components/layout/AppShell.astro';
import { HelpCircle } from '@lucide/astro';
---

<Layout title="Page Not Found | Digital Wardrobe">
	<AppShell active="">
		<section class="bg-canvas-soft py-24 min-h-[60vh] flex items-center justify-center">
			<div class="container-page max-w-md text-center">
				<div class="rounded-lg border border-hairline bg-canvas p-8 shadow-[var(--shadow-card)]">
					<div class="flex size-12 mx-auto items-center justify-center rounded-full bg-canvas-soft text-body mb-6">
						<HelpCircle size={20} stroke-width={1.8} />
					</div>
					
					<p class="font-mono text-xs text-mute mb-2 uppercase tracking-wider">Error 404</p>
					<h1 class="text-3xl font-semibold leading-10 tracking-tight text-ink mb-4">
						Page not found.
					</h1>
					<p class="text-sm leading-6 text-body mb-8">
						The page you are looking for might have been removed, had its name changed, or is temporarily unavailable.
					</p>
					
					<a class="inline-flex min-h-11 w-full items-center justify-center rounded-full bg-ink px-5 text-sm font-medium text-white transition hover:bg-ink/90 cursor-pointer" href="/">
						Go back home
					</a>
				</div>
			</div>
		</section>
	</AppShell>
</Layout>
