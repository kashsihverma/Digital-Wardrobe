---
import Layout from '../layouts/Layout.astro';
import AppShell from '../components/layout/AppShell.astro';
import { TriangleAlert } from '@lucide/astro';

interface Props {
	error: unknown;
}

const { error } = Astro.props;
const isDev = import.meta.env.DEV;
---

<Layout title="Internal Server Error | Digital Wardrobe">
	<AppShell active="">
		<section class="bg-canvas-soft py-24 min-h-[60vh] flex items-center justify-center">
			<div class="container-page max-w-2xl text-center">
				<div class="rounded-lg border border-hairline bg-canvas p-8 shadow-[var(--shadow-card)]">
					<div class="flex size-12 mx-auto items-center justify-center rounded-full bg-canvas-soft text-body mb-6">
						<TriangleAlert size={20} stroke-width={1.8} aria-hidden="true" />
					</div>
					
					<p class="font-mono text-xs text-mute mb-2 uppercase tracking-wider">Error 500</p>
					<h1 class="text-3xl font-semibold leading-10 tracking-tight text-ink mb-4">
						Something went wrong.
					</h1>
					<p class="text-sm leading-6 text-body mb-8 max-w-md mx-auto">
						We encountered an unexpected server-side error. Please try reloading the page, or return to the main dashboard.
					</p>

					{isDev && error && (
						<div class="text-left mb-8 overflow-hidden rounded-md border border-hairline bg-canvas-soft-2 p-4 text-xs font-mono">
							<p class="font-bold text-ink mb-2">Error Details (Dev Mode Only):</p>
							<pre class="overflow-x-auto text-body whitespace-pre-wrap">{error instanceof Error ? error.stack || error.message : String(error)}</pre>
						</div>
					)}
					
					<div class="flex flex-col sm:flex-row gap-3 justify-center">
						<button class="inline-flex min-h-11 items-center justify-center rounded-full bg-ink px-5 text-sm font-medium text-white transition hover:bg-ink/90 cursor-pointer" onclick="window.location.reload();">
							Reload page
						</button>
						<a class="inline-flex min-h-11 items-center justify-center rounded-full border border-hairline bg-canvas px-5 text-sm font-medium text-ink shadow-[var(--shadow-hairline)] transition hover:bg-canvas-soft cursor-pointer" href="/">
							Go back home
						</a>
					</div>
				</div>
			</div>
		</section>
	</AppShell>
</Layout>
