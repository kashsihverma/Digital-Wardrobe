---
import { Share2 } from '@lucide/astro';
import Layout from '../layouts/Layout.astro';
import AppShell from '../components/layout/AppShell.astro';
import ProductNav from '../components/layout/ProductNav.astro';
import EmptyState from '../components/wardrobe/EmptyState.astro';
import ItemPhoto from '../components/wardrobe/ItemPhoto.astro';
import { getViewDataForViewer } from '../lib/wardrobeData';

const { wardrobeItems } = await getViewDataForViewer(Astro.locals.viewer);
const hasItems = wardrobeItems.length > 0;

const collections = [
	{ title: 'June work capsule', items: wardrobeItems.slice(0, 5), note: 'Five-piece base for client days.' },
	{ title: 'Travel carry-on', items: wardrobeItems.slice(1, 6), note: 'Soft layers, airport-ready shoes, one accent.' },
	{ title: 'Dinner rotation', items: wardrobeItems.slice(3, 8), note: 'Evening looks with one warm neutral layer.' },
];
---

<Layout title="Collections | Digital Wardrobe">
	<AppShell active="/discover" private>
		<section class="bg-canvas-soft py-8">
			<ProductNav active="/discover" />
			<div class="container-page">
				<div class="mb-6 flex flex-wrap items-end justify-between gap-4">
					<div>
						<p class="font-mono text-xs text-body">LOOKBOOKS</p>
						<h1 class="mt-2 text-3xl font-semibold text-ink">Shareable collections, private items.</h1>
					</div>
					<button
						class="inline-flex min-h-10 items-center gap-2 rounded-full bg-ink px-4 text-sm font-medium text-white"
						data-copy-text="https://digital-wardrobe.local/lookbook/june-work-capsule"
						data-toast="Share card link copied. Source items remain private."
						data-track="share_link_created"
						type="button"
					>
						<Share2 size={15} strokeWidth={1.8} />
						Create share card
					</button>
				</div>
				{hasItems ? (
					<div class="grid gap-5 lg:grid-cols-3">
						{collections.map((collection) => (
							<article class="rounded-lg border border-hairline bg-canvas p-5 shadow-[var(--shadow-card)]">
								<div class="grid grid-cols-3 gap-2 rounded-lg bg-canvas-soft p-3">
									{collection.items.map((item) => (
										<div class="group/card rounded-md bg-white p-1 shadow-[var(--shadow-hairline)]">
											<ItemPhoto item={item} compact />
										</div>
									))}
								</div>
								<h2 class="mt-5 text-xl font-semibold text-ink">{collection.title}</h2>
								<p class="mt-2 text-sm leading-6 text-body">{collection.note}</p>
								<div class="mt-5 flex flex-wrap gap-2">
									<span class="rounded-full bg-canvas-soft px-3 py-1 text-xs text-body">Private source items</span>
									<span class="rounded-full bg-canvas-soft px-3 py-1 text-xs text-body">Link preview ready</span>
								</div>
								<button
									class="mt-5 min-h-10 rounded-full border border-hairline px-4 text-sm font-medium text-ink"
									data-copy-text={`https://digital-wardrobe.local/lookbook/${collection.title.toLowerCase().replaceAll(' ', '-')}`}
									data-toast={`${collection.title} share link copied.`}
									data-track="share_card_exported"
									type="button"
								>
									Copy lookbook link
								</button>
							</article>
						))}
					</div>
				) : (
					<EmptyState
						title="No collections yet."
						body="Collections are built from your wardrobe items. Add a few pieces, then group them into shareable lookbooks."
						ctaLabel="Add your first item"
						ctaEvent="dw:add-item"
					/>
				)}
			</div>
		</section>
	</AppShell>
</Layout>
