---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import { ArrowRight, CalendarDays, CheckCircle2, LockKeyhole, Sparkles, Upload, WandSparkles } from '@lucide/astro';
import heroImage from '../assets/wardrobe/digital-wardrobe-hero-v2.png';
import AppShell from '../components/layout/AppShell.astro';
import SectionHeader from '../components/sections/SectionHeader.astro';
import EventCard from '../components/wardrobe/EventCard.astro';
import ItemCard from '../components/wardrobe/ItemCard.astro';
import OutfitCard from '../components/wardrobe/OutfitCard.astro';
import StatCard from '../components/wardrobe/StatCard.astro';
import SuggestionCard from '../components/wardrobe/SuggestionCard.astro';
import { itemImages } from '../lib/itemImages';
import { getDemoViewData } from '../lib/wardrobeData';

const heroStripItems = ['camel-blazer', 'ivory-knit', 'sage-overshirt', 'structured-tote'];
const { events, insights, outfits, suggestions, wardrobeItems } = await getDemoViewData();
---

<Layout title="Digital Wardrobe | Private outfit planning and wardrobe intelligence">
	<AppShell active="/">
		<section class="relative overflow-hidden bg-canvas">
			<div class="container-page relative grid min-h-[640px] items-center gap-10 py-10 lg:min-h-[720px] lg:grid-cols-[0.9fr_1.1fr] lg:py-12">
				<div class="max-w-2xl">
					<p class="inline-flex rounded-full border border-hairline bg-canvas/80 px-3 py-1.5 font-mono text-xs text-body shadow-[var(--shadow-hairline)]">
						PRIVATE WARDROBE OS
					</p>
					<h1 class="mt-6 text-5xl font-semibold leading-[52px] text-ink md:text-6xl md:leading-[64px]">
						Plan what to wear from everything you already own.
					</h1>
					<p class="mt-6 max-w-xl text-lg leading-8 text-body">
						Digital Wardrobe turns closet photos into a searchable wardrobe, outfit canvas, event planner, and closet-health system that stays private by default.
					</p>
					<div class="mt-8 flex flex-wrap gap-3">
						<a class="inline-flex min-h-12 items-center gap-2 rounded-full bg-ink px-5 text-base font-medium text-white transition hover:bg-ink/90" href="/wardrobe">
							Open wardrobe
							<ArrowRight size={17} stroke-width={1.8} aria-hidden="true" />
						</a>
						<a class="inline-flex min-h-12 items-center gap-2 rounded-full border border-hairline bg-canvas px-5 text-base font-medium text-ink shadow-[var(--shadow-hairline)] transition hover:bg-canvas-soft" href="/outfits">
							Build outfit
						</a>
					</div>
					<div class="mt-8 grid max-w-xl gap-3 sm:grid-cols-3">
						{[
							['86', 'items digitized'],
							['24', 'outfits saved'],
							['11', 'underused pieces'],
						].map(([value, label]) => (
							<div class="rounded-lg border border-hairline bg-canvas/80 p-4 shadow-[var(--shadow-card)] backdrop-blur">
								<p class="text-2xl font-semibold text-ink">{value}</p>
								<p class="mt-1 text-sm text-body">{label}</p>
							</div>
						))}
					</div>
				</div>
				<div class="relative">
					<div class="mb-3 grid grid-cols-4 gap-2">
						{heroStripItems.map((itemId) => {
							const item = wardrobeItems.find((candidate) => candidate.id === itemId);
							const image = itemImages[itemId];

							return image && item ? (
								<div class="overflow-hidden rounded-md border border-hairline bg-canvas shadow-[var(--shadow-card)]">
									<Image
										alt={`${item.name} product photo`}
										class="aspect-[4/3] w-full object-cover"
										loading="eager"
										sizes="(min-width: 1024px) 180px, 25vw"
										src={image}
										widths={[120, 180, 240, 320]}
									/>
								</div>
							) : null;
						})}
					</div>
					<div class="rounded-lg border border-hairline bg-canvas p-2 shadow-[var(--shadow-float)]">
						<Image
							alt="Tablet and phone showing a clean Digital Wardrobe interface with garment cards, outfit planning, and calendar panels"
							class="aspect-[16/9] w-full rounded-lg object-cover"
							loading="eager"
							fetchpriority="high"
							src={heroImage}
						/>
					</div>
					<div class="absolute -bottom-6 left-6 right-6 hidden rounded-lg border border-hairline bg-canvas p-4 shadow-[var(--shadow-float)] md:block">
						<div class="flex items-center gap-3">
							<div class="flex size-10 items-center justify-center rounded-full bg-ink text-white">
								<WandSparkles size={16} stroke-width={1.8} aria-hidden="true" />
							</div>
							<div>
								<p class="text-sm font-medium text-ink">Suggested for Friday.</p>
								<p class="text-sm text-body">Camel blazer, ivory knit, cream trouser.</p>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section class="border-y border-hairline bg-canvas-soft py-16" id="product-system">
			<div class="container-page">
				<SectionHeader
					eyebrow="Product system"
					title="Capture, organize, search, outfit, plan."
					body="The site follows the blueprint's phased flow: quick item ingestion, confidence-aware tags, visual inventory, outfit composition, event planning, discovery, and insight loops."
				/>
				<div class="mt-10 grid gap-4 md:grid-cols-2 lg:grid-cols-5">
					{[
						[Upload, 'Capture', 'Camera, upload, screenshot, or link import with one-screen confirmation.'],
						[CheckCircle2, 'Auto-tag', 'Category, color, occasion, season, and notes stay editable.'],
						[Sparkles, 'Style', 'Item, event, and closet-health suggestions explain why they appear.'],
						[CalendarDays, 'Plan', 'Manual events ship first; calendar sync remains an upgrade path.'],
						[LockKeyhole, 'Privacy', 'Wardrobe, tags, events, and shares start private by default.'],
					].map(([Icon, title, body]) => (
						<article class="rounded-lg border border-hairline bg-canvas p-5 shadow-[var(--shadow-card)]">
							<div class="flex size-10 items-center justify-center rounded-full bg-canvas-soft text-ink">
								<Icon size={18} stroke-width={1.8} aria-hidden="true" />
							</div>
							<h3 class="mt-5 text-lg font-semibold text-ink">{title}</h3>
							<p class="mt-2 text-sm leading-6 text-body">{body}</p>
						</article>
					))}
				</div>
			</div>
		</section>

		<section class="bg-canvas py-20">
			<div class="container-page grid gap-8 lg:grid-cols-[0.85fr_1.15fr]">
				<div>
					<SectionHeader
						eyebrow="Today"
						title="A dashboard that starts with the next decision."
						body="Weather, events, recent uploads, and wardrobe health sit in one calm command center instead of a cluttered closet dump."
					/>
					<div class="mt-8 grid gap-4">
						{suggestions.map((suggestion) => <SuggestionCard suggestion={suggestion} />)}
					</div>
				</div>
				<div class="grid gap-4">
					<div class="grid gap-4 sm:grid-cols-2">
						{insights.slice(0, 2).map((metric) => <StatCard {...metric} />)}
					</div>
					{events[0] && <EventCard event={events[0]} />}
					{outfits[0] && <OutfitCard outfit={outfits[0]} items={wardrobeItems} />}
				</div>
			</div>
		</section>

		<section class="bg-ink py-20 text-white" id="privacy">
			<div class="container-page grid gap-10 lg:grid-cols-[0.85fr_1.15fr]">
				<div>
					<p class="font-mono text-xs text-white/60">WARDROBE GRID</p>
					<h2 class="mt-3 text-3xl font-semibold leading-10 md:text-[32px]">
						Image-first browsing without ecommerce noise.
					</h2>
					<p class="mt-4 text-base leading-7 text-white/70">
						Item cards prioritize cutouts, tags, wear count, tag confidence, and status markers. Discovery can become richer; inventory stays clean.
					</p>
				</div>
				<div class="grid grid-cols-2 gap-3 md:grid-cols-3">
					{wardrobeItems.slice(0, 6).map((item) => <ItemCard item={item} />)}
				</div>
			</div>
		</section>

		<section class="border-t border-hairline bg-canvas-soft py-16" id="seo-info">
			<div class="container-page">
				<p class="font-mono text-xs text-body mb-3 uppercase tracking-wider">Closet systems & intelligence</p>
				<h2 class="text-3xl font-semibold leading-10 tracking-tight text-ink md:text-4xl mb-8">
					Optimize your style with a modern digital wardrobe.
				</h2>
				<div class="grid gap-8 md:grid-cols-2 text-sm leading-7 text-body">
					<div>
						<p class="mb-4">
							Organizing clothing and planning daily looks has evolved beyond physical storage. In the modern era, managing your apparel starts with a high-performance <strong>digital wardrobe</strong>. By transitioning from traditional hangers to digital cataloging, anyone can optimize their styling decisions with ease. This transition is made simple through a specialized <strong>digital wardrobe app</strong> designed to help users upload, classify, and track their clothing items. This approach replaces guesswork with clarity.
						</p>
						<p class="mb-4">
							Instead of feeling overwhelmed by a cluttered physical space, you can catalog your <strong>wardrobe-closet</strong> into a visual database. This digital approach enables seamless planning, giving you full control of your daily style. Managing a physical catalog becomes effortless once you have digitized every garment. Users can easily view color distributions, identify duplicate items, and understand gaps in their styling options. Ultimately, a structured virtual catalog transforms how we approach getting dressed each morning, making look planning a creative rather than stressful experience. By having your clothes organized digitally, you can plan outfits from anywhere.
						</p>
						<p>
							Efficient organization begins with understanding space and visual layout. The architecture of a modern <strong>wardrobe closet</strong> relies on structured curation and intelligence. By implementing principles of <strong>online closet design</strong>, users can visualize how different items coordinate before physically putting them on. Whether you are arranging an existing collection or starting from scratch, designing a balanced <strong>closet wardrobe</strong> requires a clear, visual overview of all garments. This strategy ensures you maintain a clean closet flow and make the most out of every piece you own.
						</p>
					</div>
					<div>
						<p class="mb-4">
							Our web application functions as an intelligent <strong>online closet</strong> that lets you categorize garments by color, season, and occasion. By using clean spacing rules and elegant typography, the dashboard acts as a visual representation of your actual closet. Having a clear overview of your items makes styling simple, reducing morning friction and preventing unnecessary purchases of items you already own, thereby extending the lifecycle of your clothes. This makes outfit planning fun and highly efficient.
						</p>
						<p class="mb-4">
							Building a functional system requires the right tools. Instead of relying on manual sorting or static spreadsheets, users can leverage an interactive <strong>online closet design tool</strong> to compose outfits dynamically on a digital canvas. Our platform integrates advanced components that model real-world <strong>online closet systems</strong>, showing analytics like wear count, cost-per-wear, and seasonal utility. This data-driven perspective changes how we interact with our clothes. By monitoring how often you wear specific items, you gain valuable insights into your personal style.
						</p>
						<p class="mb-4">
							If you are looking to plan layout options and visualize your garment spacing, our platform serves as an <strong>online closet design tool free</strong> of charge, offering premium features without paywalls. Providing access to a <strong>free online closet design tool</strong> ensures that everyone can enjoy structured closet optimization without initial cost. By removing barriers to entry, we encourage users to curate their wardrobes mindfully, creating sustainable habits and smarter fashion choices that benefit both their styling and their budget.
						</p>
						<p>
							The future of personal style is data-driven, visual, and highly organized. Using an <strong>online closet designer</strong> helps bridge the gap between inspiration and reality. By suggesting outfits tailored to your calendar, upcoming weather, and historical preferences, a digital system ensures your wardrobe is fully utilized. Experience the benefits of a completely integrated digital assistant that guides your styling choices daily. Every user receives tailored suggestions based on their usage history, pointing out underused garments and encouraging creative outfit combinations, proving that a well-managed closet leads to a more mindful wardrobe. This is the ultimate system for smart dressing.
						</p>
					</div>
				</div>
			</div>
		</section>

		<section class="border-t border-hairline bg-canvas py-16" id="faq">
			<div class="container-page max-w-4xl">
				<p class="font-mono text-xs text-body mb-3 uppercase tracking-wider text-center">Frequently asked questions</p>
				<h2 class="text-3xl font-semibold leading-10 tracking-tight text-ink md:text-4xl mb-10 text-center">
					Questions & answers.
				</h2>
				
				<div class="space-y-4">
					<details class="group border-b border-hairline pb-4">
						<summary class="flex justify-between items-center font-medium text-ink cursor-pointer list-none py-2 select-none hover:text-ink/80 transition">
							<span>How to make a digital closet?</span>
							<span class="transition-transform duration-200 group-open:rotate-180">
								<svg class="size-4 text-body" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
									<path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
								</svg>
							</span>
						</summary>
						<p class="mt-2 text-sm leading-6 text-body">
							To make a digital closet, start by photographing your entire wardrobe against a neutral background. Crop and remove backgrounds using a mobile editor or digital wardrobe app. Then, upload the clean garment images into a cataloging tool, tagging each piece with metadata like category, color, season, and occasion to keep your collection searchable and organized.
						</p>
					</details>

					<details class="group border-b border-hairline pb-4">
						<summary class="flex justify-between items-center font-medium text-ink cursor-pointer list-none py-2 select-none hover:text-ink/80 transition">
							<span>How to make a digital wardrobe?</span>
							<span class="transition-transform duration-200 group-open:rotate-180">
								<svg class="size-4 text-body" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
									<path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
								</svg>
							</span>
						</summary>
						<p class="mt-2 text-sm leading-6 text-body">
							Making a digital wardrobe involves digitizing your physical garments and using an online closet design tool to plan outfits. Catalog all items in a central database, track their usage data (such as wear count and cost-per-wear), and create digital outfit grids to plan look combinations for upcoming events, saving you time and money.
						</p>
					</details>

					<details class="group border-b border-hairline pb-4">
						<summary class="flex justify-between items-center font-medium text-ink cursor-pointer list-none py-2 select-none hover:text-ink/80 transition">
							<span>What is a capsule wardrobe?</span>
							<span class="transition-transform duration-200 group-open:rotate-180">
								<svg class="size-4 text-body" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
									<path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
								</svg>
							</span>
						</summary>
						<p class="mt-2 text-sm leading-6 text-body">
							A capsule wardrobe is a curated collection of a limited number of versatile, high-quality clothing items that can be easily interchanged to create a wide variety of outfits. Typically focused on neutral colors and classic silhouettes, it simplifies daily styling and reduces clothing waste.
						</p>
					</details>

					<details class="group border-b border-hairline pb-4">
						<summary class="flex justify-between items-center font-medium text-ink cursor-pointer list-none py-2 select-none hover:text-ink/80 transition">
							<span>How to organize men's wardrobe?</span>
							<span class="transition-transform duration-200 group-open:rotate-180">
								<svg class="size-4 text-body" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
									<path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
								</svg>
							</span>
						</summary>
						<p class="mt-2 text-sm leading-6 text-body">
							Organize a men's wardrobe by first categorizing items by garment type (shirts, trousers, blazers, shoes) and color. Hang structured garments like suits and button-downs, fold knitwear to prevent stretching, and arrange shoes by style. Use a digital wardrobe organizer to track which pieces get the most use.
						</p>
					</details>

					<details class="group border-b border-hairline pb-4">
						<summary class="flex justify-between items-center font-medium text-ink cursor-pointer list-none py-2 select-none hover:text-ink/80 transition">
							<span>How to build a capsule wardrobe?</span>
							<span class="transition-transform duration-200 group-open:rotate-180">
								<svg class="size-4 text-body" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
									<path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
								</svg>
							</span>
						</summary>
						<p class="mt-2 text-sm leading-6 text-body">
							To build a capsule wardrobe, audit your existing closet to identify garments you wear most frequently. Choose a cohesive color palette (e.g., navy, grey, white, black) and invest in key staples like a tailored blazer, white t-shirts, classic denim, and neutral knitwear. Ensure every item coordinates with at least three others.
						</p>
					</details>

					<details class="group border-b border-hairline pb-4">
						<summary class="flex justify-between items-center font-medium text-ink cursor-pointer list-none py-2 select-none hover:text-ink/80 transition">
							<span>How to organize a small closet?</span>
							<span class="transition-transform duration-200 group-open:rotate-180">
								<svg class="size-4 text-body" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
									<path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
								</svg>
							</span>
						</summary>
						<p class="mt-2 text-sm leading-6 text-body">
							To organize a small closet, maximize vertical space by using slim velvet hangers, hanging closet organizers, and storage bins on top shelves. Store off-season clothes in vacuum-sealed bags, declare items you no longer wear, and utilize a digital closet tool to plan outfits without creating physical clutter.
						</p>
					</details>
				</div>
			</div>
		</section>

		<script type="application/ld+json" is:raw>
		{
			"@context": "https://schema.org",
			"@type": "FAQPage",
			"mainEntity": [
				{
					"@type": "Question",
					"name": "How to make a digital closet?",
					"acceptedAnswer": {
						"@type": "Answer",
						"text": "<p>To make a digital closet, start by photographing your entire wardrobe against a neutral background. Crop and remove backgrounds using a mobile editor or digital wardrobe app. Then, upload the clean garment images into a cataloging tool, tagging each piece with metadata like category, color, season, and occasion to keep your collection searchable and organized.</p>"
					}
				},
				{
					"@type": "Question",
					"name": "How to make a digital wardrobe?",
					"acceptedAnswer": {
						"@type": "Answer",
						"text": "<p>Making a digital wardrobe involves digitizing your physical garments and using an online closet design tool to plan outfits. Catalog all items in a central database, track their usage data (such as wear count and cost-per-wear), and create digital outfit grids to plan look combinations for upcoming events, saving you time and money.</p>"
					}
				},
				{
					"@type": "Question",
					"name": "What is a capsule wardrobe?",
					"acceptedAnswer": {
						"@type": "Answer",
						"text": "<p>A capsule wardrobe is a curated collection of a limited number of versatile, high-quality clothing items that can be easily interchanged to create a wide variety of outfits. Typically focused on neutral colors and classic silhouettes, it simplifies daily styling and reduces clothing waste.</p>"
					}
				},
				{
					"@type": "Question",
					"name": "How to organize men's wardrobe?",
					"acceptedAnswer": {
						"@type": "Answer",
						"text": "<p>Organize a men's wardrobe by first categorizing items by garment type (shirts, trousers, blazers, shoes) and color. Hang structured garments like suits and button-downs, fold knitwear to prevent stretching, and arrange shoes by style. Use a digital wardrobe organizer to track which pieces get the most use.</p>"
					}
				},
				{
					"@type": "Question",
					"name": "How to build a capsule wardrobe?",
					"acceptedAnswer": {
						"@type": "Answer",
						"text": "<p>To build a capsule wardrobe, audit your existing closet to identify garments you wear most frequently. Choose a cohesive color palette (e.g., navy, grey, white, black) and invest in key staples like a tailored blazer, white t-shirts, classic denim, and neutral knitwear. Ensure every item coordinates with at least three others.</p>"
					}
				},
				{
					"@type": "Question",
					"name": "How to organize a small closet?",
					"acceptedAnswer": {
						"@type": "Answer",
						"text": "<p>To organize a small closet, maximize vertical space by using slim velvet hangers, hanging closet organizers, and storage bins on top shelves. Store off-season clothes in vacuum-sealed bags, declare items you no longer wear, and utilize a digital closet tool to plan outfits without creating physical clutter.</p>"
					}
				}
			]
		}
		</script>
	</AppShell>
</Layout>
