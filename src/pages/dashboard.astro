---
import { ArrowRight, CalendarDays, ChartNoAxesColumnIncreasing, Shirt, WandSparkles } from '@lucide/astro';
import Layout from '../layouts/Layout.astro';
import AppShell from '../components/layout/AppShell.astro';
import EmptyState from '../components/wardrobe/EmptyState.astro';
import EventCard from '../components/wardrobe/EventCard.astro';
import ItemCard from '../components/wardrobe/ItemCard.astro';
import OutfitCard from '../components/wardrobe/OutfitCard.astro';
import StatCard from '../components/wardrobe/StatCard.astro';
import SuggestionCard from '../components/wardrobe/SuggestionCard.astro';
import { getViewDataForViewer } from '../lib/wardrobeData';

const { events, insights, outfits, suggestions, wardrobeItems } = await getViewDataForViewer(Astro.locals.viewer);
const hasItems = wardrobeItems.length > 0;
const featuredOutfit = outfits[0];
---

<Layout title="Today | Digital Wardrobe">
	<AppShell active="/dashboard" private>
		<section class="bg-canvas-soft py-8">
			<div class="container-page">
				<div class="mb-6 flex flex-wrap items-end justify-between gap-4">
					<div>
						<p class="font-mono text-xs text-body">TODAY</p>
						<h1 class="mt-2 text-3xl font-semibold tracking-[-0.96px] text-ink">Your next outfit decision, already organized.</h1>
					</div>
					<a class="inline-flex min-h-10 items-center gap-2 rounded-full bg-ink px-4 text-sm font-medium text-white" href="/wardrobe">
						Open wardrobe
						<ArrowRight size={15} stroke-width={1.8} aria-hidden="true" />
					</a>
				</div>

				{hasItems ? (
					<div class="grid gap-6 xl:grid-cols-[1fr_360px]">
						<section class="grid gap-5">
							<div class="rounded-lg border border-hairline bg-canvas p-5 shadow-[var(--shadow-card)]">
								<div class="flex flex-wrap items-start justify-between gap-4 border-b border-hairline pb-5">
									<div>
										<p class="font-mono text-xs text-body">RECOMMENDED</p>
										<h2 class="mt-2 text-2xl font-semibold tracking-[-0.96px] text-ink">Start with the outfit that fits today.</h2>
									</div>
									<div class="flex size-11 items-center justify-center rounded-full bg-ink text-white">
										<WandSparkles size={17} stroke-width={1.8} aria-hidden="true" />
									</div>
								</div>
								<div class="mt-5 grid gap-5 lg:grid-cols-[0.9fr_1.1fr]">
									<div class="grid content-start gap-3">
										{suggestions.slice(0, 3).map((suggestion) => <SuggestionCard suggestion={suggestion} />)}
										{suggestions.length === 0 && <p class="text-sm leading-6 text-body">Suggestions appear as you save outfits and log wears.</p>}
									</div>
									{featuredOutfit ? (
										<OutfitCard outfit={featuredOutfit} items={wardrobeItems} />
									) : (
										<div class="grid place-items-center rounded-lg border border-dashed border-hairline bg-canvas-soft p-6 text-center text-sm text-body">
											Save an outfit to feature it here.
										</div>
									)}
								</div>
							</div>

							{insights.length > 0 && (
								<div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
									{insights.map((metric) => <StatCard {...metric} />)}
								</div>
							)}

							<section class="rounded-lg border border-hairline bg-canvas p-5 shadow-[var(--shadow-card)]">
								<div class="flex items-center justify-between gap-3">
									<div>
										<p class="font-mono text-xs text-body">RECENT ITEMS</p>
										<h2 class="mt-1 text-xl font-semibold text-ink">New and useful pieces.</h2>
									</div>
									<Shirt class="text-body" size={18} stroke-width={1.8} aria-hidden="true" />
								</div>
								<div class="mt-5 grid grid-cols-2 gap-3 md:grid-cols-4">
									{wardrobeItems.slice(0, 4).map((item) => <ItemCard item={item} />)}
								</div>
							</section>
						</section>

						<aside class="grid content-start gap-4">
							<div class="rounded-lg border border-hairline bg-ink p-5 text-white shadow-[var(--shadow-float)]">
								<p class="font-mono text-xs text-white/60">WARDROBE HEALTH</p>
								<h2 class="mt-3 text-xl font-semibold">Keep the closet moving.</h2>
								<p class="mt-2 text-sm leading-6 text-white/70">Review underused pieces, save outfits ahead, and keep event looks ready.</p>
								<div class="mt-5 flex items-center gap-3 text-sm text-white/80">
									<ChartNoAxesColumnIncreasing size={16} stroke-width={1.8} aria-hidden="true" />
									Cost per wear is improving this month.
								</div>
							</div>
							<div class="grid gap-3">
								<div class="flex items-center gap-2">
									<CalendarDays class="text-body" size={16} stroke-width={1.8} aria-hidden="true" />
									<p class="font-mono text-xs text-body">UPCOMING</p>
								</div>
								{events.slice(0, 3).map((event) => <EventCard event={event} />)}
								{events.length === 0 && <p class="text-sm text-body">No events planned yet.</p>}
							</div>
						</aside>
					</div>
				) : (
					<EmptyState
						title="Welcome to your wardrobe."
						body="It's empty for now. Add your first piece — snap a photo, upload an image, or paste a product link — and your dashboard fills in from there."
						ctaLabel="Add your first item"
						ctaEvent="dw:add-item"
					/>
				)}
			</div>
		</section>
	</AppShell>
</Layout>
